# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/wellconnect
DB_USERNAME=postgres
DB_PASSWORD=your_password

# JWT Configuration (Generate a secure random string)
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-must-be-at-least-32-characters
JWT_EXPIRATION=86400000

# Encryption Configuration (Must be exactly 16 characters for AES-128)
ENCRYPTION_KEY=1234567890123456

# Server Configuration
SERVER_PORT=8080
